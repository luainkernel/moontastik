# Pinned versions for the VM test environment.
# Single source of truth — sourced by the scripts and hashed for CI caching.

# Linux LTS kernel the tests run against.
KERNEL_VERSION=6.18.35

# Lunatik source: pinned on jperon's fork until the fix_crypto_enomem PR
# is merged into luainkernel/lunatik master.
LUNATIK_REPO=https://github.com/jperon/lunatik
LUNATIK_REF=fix_crypto_enomem
