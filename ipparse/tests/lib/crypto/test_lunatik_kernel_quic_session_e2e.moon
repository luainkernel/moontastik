-- tests/lib/crypto/test_lunatik_kernel_quic_session_e2e.moon
-- Lunatik E2E on real quic.pcapng data (embedded real metadata + real TLS stream).

quic_l7 = require "ipparse.l7.quic"

hex_to_bin = (hex) ->
  out = {}
  j = 1
  for i = 1, #hex, 2
    out[j] = string.char tonumber(hex\sub(i, i + 1), 16)
    j += 1
  table.concat out

tests_passed = 0
tests_failed = 0

assert_test = (name, fn) ->
  ok, err = pcall fn
  if ok
    tests_passed += 1
    print "PASS\tlunatik: #{name}"
  else
    tests_failed += 1
    print "FAIL\tlunatik: #{name}\t#{err}"
    error err

SRC_MAC = "e0:8f:4c:c8:91:fa"
DST_MAC = "a4:2b:b0:f2:c1:fc"
SRC_IP  = "2001:867:f:a009::f13"
DST_IP  = "2606:4700:4400::ac40:996e"
UDP_SRC = 44339
UDP_DST = 443

