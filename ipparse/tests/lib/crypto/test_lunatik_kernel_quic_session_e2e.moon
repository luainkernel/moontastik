assert_test "Kernel E2E uses real capture endpoints", ->
  print "INFO\tlunatik: L2 src_mac=#{SRC_MAC} dst_mac=#{DST_MAC}"
  print "INFO\tlunatik: L3 src_ip=#{SRC_IP} dst_ip=#{DST_IP}"
  print "INFO\tlunatik: L4 udp_src=#{UDP_SRC} udp_dst=#{UDP_DST}"
  true

assert_test "Kernel E2E extracts real SNI from real TLS stream", ->
  tls_stream = hex_to_bin REAL_TLS_STREAM_HEX
  sni = quic_l7.sni_from_tls tls_stream
  assert sni == "clerk.openrouter.ai", "expected clerk.openrouter.ai, got #{tostring sni}"
  print "INFO\tlunatik: L7 sni=#{sni}"

print "  --> lib.crypto.lunatik.kernel.quic_session_e2e: #{tests_passed}/#{tests_passed + tests_failed}"
